<Window x:Class="CabinetDesigner.Presentation.Views.AlphaLimitationsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Alpha Limitations"
        Width="860"
        Height="680"
        MinWidth="760"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ShellWindowBrush}"
        FontFamily="Segoe UI"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/CabinetDesigner.Presentation;component/Views/Resources/ShellResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource ShellCardStyle}">
            <StackPanel>
                <TextBlock Text="Alpha limitations"
                           Style="{StaticResource ShellSectionTitleStyle}" />
                <TextBlock Text="This list collects the flows that are intentionally incomplete in alpha so testers get a clear explanation instead of a dead end."
                           Style="{StaticResource ShellSectionSubtitleStyle}"
                           Margin="0,4,0,0" />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Groups}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Expander IsExpanded="True"
                                  Margin="0,0,0,12"
                                  Background="{StaticResource ShellSurfaceBrush}"
                                  BorderBrush="{StaticResource ShellBorderSoftBrush}"
                                  BorderThickness="1"
                                  Padding="12">
                            <Expander.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding AreaLabel}"
                                               Style="{StaticResource ShellSectionTitleStyle}" />
                                    <TextBlock Text="{Binding Limitations.Count, StringFormat={}{0} items}"
                                               Style="{StaticResource ShellMiniLabelStyle}"
                                               Margin="10,2,0,0" />
                                </StackPanel>
                            </Expander.Header>

                            <ItemsControl ItemsSource="{Binding Limitations}"
                                          Margin="0,10,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource ShellCatalogItemCardStyle}"
                                                Margin="0,0,0,10">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Code}"
                                                           Style="{StaticResource ShellMiniLabelStyle}" />
                                                <TextBlock Text="{Binding Title}"
                                                           Style="{StaticResource ShellStatusBadgeTextStyle}"
                                                           Margin="0,4,0,0"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding UserFacingMessage}"
                                                           Style="{StaticResource ShellSectionSubtitleStyle}"
                                                           Margin="0,4,0,0" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Expander>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="OK"
                    Command="{Binding CloseCommand}"
                    Style="{StaticResource ShellToolbarButtonStyle}"
                    IsDefault="True"
                    Margin="0" />
        </StackPanel>
    </Grid>
</Window>
