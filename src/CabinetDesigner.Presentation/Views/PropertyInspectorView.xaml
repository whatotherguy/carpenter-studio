<UserControl x:Class="CabinetDesigner.Presentation.Views.PropertyInspectorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:CabinetDesigner.Presentation.Views"
             Background="Transparent">
    <Border Style="{StaticResource ShellCardStyle}"
            Padding="0">
        <DockPanel LastChildFill="True">
            <views:ShellPanelHeaderView DockPanel.Dock="Top"
                                        Title="Property Inspector"
                                        Subtitle="Inspect and edit cabinet properties."
                                        Margin="0,0,0,12">
                <views:ShellPanelHeaderView.RightContent>
                    <StackPanel HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Border Style="{StaticResource ShellBadgeStyle}"
                                Margin="0,0,0,6">
                            <TextBlock Text="{Binding SourceLabel}"
                                       Style="{StaticResource ShellBadgeTextStyle}" />
                        </Border>
                        <Border Style="{StaticResource ShellBadgeStyle}"
                                Margin="0,0,0,6">
                            <TextBlock Text="{Binding EditabilityStatusDisplay}"
                                       Style="{StaticResource ShellBadgeTextStyle}" />
                        </Border>
                        <TextBlock Text="{Binding SelectionSummaryDisplay}"
                                   Style="{StaticResource ShellMiniLabelStyle}"
                                   HorizontalAlignment="Right" />
                    </StackPanel>
                </views:ShellPanelHeaderView.RightContent>
            </views:ShellPanelHeaderView>

            <ScrollViewer Style="{StaticResource ShellCatalogListScrollViewerStyle}">
                <StackPanel Margin="0,0,0,12">
                    <Border Style="{StaticResource ShellStatusBadgeStyle}"
                            Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Selected entity"
                                       Style="{StaticResource ShellMiniLabelStyle}" />
                            <TextBlock Text="{Binding SelectedEntityLabel}"
                                       Style="{StaticResource ShellStatusBadgeTextStyle}"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource ShellPropertyCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Identity"
                                       Style="{StaticResource ShellSectionTitleStyle}" />
                            <TextBlock Text="{Binding DisplayName}"
                                       Style="{StaticResource ShellStatusBadgeTextStyle}"
                                       Margin="0,6,0,0" />
                            <TextBlock Text="Display name is derived from cabinet type and instance ordinal."
                                       Style="{StaticResource ShellMiniLabelStyle}"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource ShellPropertyCardStyle}"
                            Margin="0,12,0,0">
                        <StackPanel>
                            <TextBlock Text="Dimensions"
                                       Style="{StaticResource ShellSectionTitleStyle}" />
                            <UniformGrid Columns="3"
                                         Margin="0,8,0,0">
                                <StackPanel Margin="0,0,8,0">
                                    <TextBlock Text="Width"
                                               Style="{StaticResource ShellPropertyKeyStyle}" />
                                    <TextBlock Text="{Binding NominalWidth}"
                                               Style="{StaticResource ShellStatusBadgeTextStyle}" />
                                </StackPanel>
                                <StackPanel Margin="8,0,8,0">
                                    <TextBlock Text="Depth"
                                               Style="{StaticResource ShellPropertyKeyStyle}" />
                                    <TextBlock Text="{Binding Depth}"
                                               Style="{StaticResource ShellStatusBadgeTextStyle}" />
                                </StackPanel>
                                <StackPanel Margin="8,0,0,0">
                                    <TextBlock Text="Height"
                                               Style="{StaticResource ShellPropertyKeyStyle}" />
                                    <TextBlock Text="{Binding Height}"
                                               Style="{StaticResource ShellStatusBadgeTextStyle}" />
                                </StackPanel>
                            </UniformGrid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource ShellPropertyCardStyle}"
                            Margin="0,12,0,0">
                        <StackPanel>
                            <TextBlock Text="Cabinet Settings"
                                       Style="{StaticResource ShellSectionTitleStyle}" />
                            <UniformGrid Columns="2"
                                         Margin="0,8,0,0">
                                <StackPanel Margin="0,0,8,8">
                                    <TextBlock Text="Category"
                                               Style="{StaticResource ShellPropertyKeyStyle}" />
                                    <TextBlock Text="{Binding Category}"
                                               Style="{StaticResource ShellStatusBadgeTextStyle}" />
                                </StackPanel>
                                <StackPanel Margin="8,0,0,8">
                                    <TextBlock Text="Construction"
                                               Style="{StaticResource ShellPropertyKeyStyle}" />
                                    <TextBlock Text="{Binding Construction}"
                                               Style="{StaticResource ShellStatusBadgeTextStyle}" />
                                </StackPanel>
                                <StackPanel Margin="0,8,8,0">
                                    <TextBlock Text="Shelf Count"
                                               Style="{StaticResource ShellPropertyKeyStyle}" />
                                    <TextBlock Text="{Binding ShelfCount}"
                                               Style="{StaticResource ShellStatusBadgeTextStyle}" />
                                </StackPanel>
                                <StackPanel Margin="8,8,0,0">
                                    <TextBlock Text="Toe Kick Height"
                                               Style="{StaticResource ShellPropertyKeyStyle}" />
                                    <TextBlock Text="{Binding ToeKickHeight}"
                                               Style="{StaticResource ShellStatusBadgeTextStyle}" />
                                </StackPanel>
                            </UniformGrid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource ShellPropertyCardStyle}"
                            Margin="0,12,0,0">
                        <StackPanel>
                            <TextBlock Text="Openings"
                                       Style="{StaticResource ShellSectionTitleStyle}" />
                            <ItemsControl ItemsSource="{Binding Openings}"
                                          Margin="0,8,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource ShellCatalogListItemBorderStyle}"
                                                Margin="0,0,0,8">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Type}"
                                                           Style="{StaticResource ShellStatusBadgeTextStyle}" />
                                                <TextBlock Text="{Binding Width}"
                                                           Style="{StaticResource ShellMiniLabelStyle}" />
                                                <TextBlock Text="{Binding Height}"
                                                           Style="{StaticResource ShellMiniLabelStyle}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource ShellPropertyCardStyle}"
                            Margin="0,12,0,0">
                        <StackPanel>
                            <TextBlock Text="Material Overrides"
                                       Style="{StaticResource ShellSectionTitleStyle}" />
                            <ItemsControl ItemsSource="{Binding MaterialOverrides}"
                                          Margin="0,8,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource ShellCatalogListItemBorderStyle}"
                                                Margin="0,0,0,8">
                                            <StackPanel>
                                                <TextBlock Text="{Binding DisplayName}"
                                                           Style="{StaticResource ShellStatusBadgeTextStyle}" />
                                                <TextBlock Text="{Binding DisplayValue}"
                                                           Style="{StaticResource ShellMiniLabelStyle}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource ShellPropertyCardStyle}"
                            Margin="0,12,0,0">
                        <StackPanel>
                            <TextBlock Text="Thickness Overrides"
                                       Style="{StaticResource ShellSectionTitleStyle}" />
                            <ItemsControl ItemsSource="{Binding ThicknessOverrides}"
                                          Margin="0,8,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource ShellCatalogListItemBorderStyle}"
                                                Margin="0,0,0,8">
                                            <StackPanel>
                                                <TextBlock Text="{Binding DisplayName}"
                                                           Style="{StaticResource ShellStatusBadgeTextStyle}" />
                                                <TextBlock Text="{Binding DisplayValue}"
                                                           Style="{StaticResource ShellMiniLabelStyle}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource ShellPropertyCardStyle}"
                            Margin="0,12,0,0">
                        <StackPanel>
                            <TextBlock Text="Notes"
                                       Style="{StaticResource ShellSectionTitleStyle}" />
                            <TextBlock Text="{Binding Notes}"
                                       Style="{StaticResource ShellStatusBadgeTextStyle}"
                                       Margin="0,6,0,0"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <ItemsControl Style="{StaticResource ShellPropertyItemsControlStyle}"
                                  ItemsSource="{Binding Properties}"
                                  ItemTemplate="{StaticResource PropertyRowTemplate}"
                                  Margin="0,12,0,0" />
                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Border>
</UserControl>
