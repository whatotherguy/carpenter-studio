<UserControl x:Class="CabinetDesigner.Presentation.Views.CatalogPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:CabinetDesigner.Presentation.Views"
             Background="Transparent">
    <Border Style="{StaticResource ShellCardStyle}">
        <DockPanel LastChildFill="True">
            <views:ShellPanelHeaderView DockPanel.Dock="Top"
                                        Title="Catalog"
                                        Subtitle="Browse cabinet types and narrow the list with search."
                                        Margin="0,0,0,12">
                <views:ShellPanelHeaderView.RightContent>
                    <StackPanel Orientation="Vertical"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Border Style="{StaticResource ShellBadgeStyle}"
                                Margin="0,0,0,6">
                            <TextBlock Text="{Binding SourceLabel}"
                                       Style="{StaticResource ShellBadgeTextStyle}" />
                        </Border>
                        <TextBlock Text="{Binding ItemCountText}"
                                   Style="{StaticResource ShellMiniLabelStyle}"
                                   HorizontalAlignment="Right" />
                    </StackPanel>
                </views:ShellPanelHeaderView.RightContent>
            </views:ShellPanelHeaderView>

            <StackPanel DockPanel.Dock="Top"
                        Margin="0,0,0,12">
                <TextBlock Text="Search"
                           Style="{StaticResource ShellMiniLabelStyle}"
                           Margin="2,0,0,6" />
                <TextBox Style="{StaticResource ShellCatalogSearchBoxStyle}"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Text="Search by name, category, type id, description, or width."
                           Style="{StaticResource ShellSectionSubtitleStyle}" />
            </StackPanel>

            <Grid>
                <ScrollViewer Style="{StaticResource ShellCatalogListScrollViewerStyle}">
                    <ItemsControl Style="{StaticResource ShellCatalogItemsControlStyle}"
                                  ItemsSource="{Binding FilteredItems}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource ShellCatalogItemCardStyle}"
                                        PreviewMouseLeftButtonDown="OnItemPreviewMouseLeftButtonDown"
                                        PreviewMouseMove="OnItemPreviewMouseMove"
                                        PreviewMouseLeftButtonUp="OnItemMouseLeftButtonUp">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <Border Style="{StaticResource ShellCatalogCategoryPillStyle}" Margin="0,0,8,0">
                                                    <TextBlock Text="{Binding Category}"
                                                               Style="{StaticResource ShellCatalogCategoryTextStyle}" />
                                                </Border>
                                                <TextBlock Text="{Binding TypeId}"
                                                           Style="{StaticResource ShellCatalogMetaStyle}"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding DisplayName}"
                                                       Style="{StaticResource ShellCatalogDisplayNameStyle}" />
                                            <TextBlock Text="{Binding Description}"
                                                       Style="{StaticResource ShellCatalogMetaStyle}"
                                                       Margin="0,3,0,0" />
                                            <TextBlock Text="{Binding ConstructionMethod}"
                                                       Style="{StaticResource ShellCatalogMetaStyle}"
                                                       Margin="0,3,0,0" />
                                            <TextBlock Text="{Binding DimensionsDisplay}"
                                                       Style="{StaticResource ShellCatalogMetaStyle}"
                                                       Margin="0,3,0,0" />
                                            <TextBlock Text="{Binding DefaultOpeningsDisplay}"
                                                       Style="{StaticResource ShellCatalogMetaStyle}"
                                                       Margin="0,3,0,0" />
                                            <TextBlock Text="{Binding DefaultWidthDisplay}"
                                                       Style="{StaticResource ShellCatalogMetaStyle}"
                                                       Margin="0,3,0,0" />
                                        </StackPanel>

                                        <Border Grid.Column="1"
                                                Style="{StaticResource ShellCatalogWidthBadgeStyle}">
                                            <StackPanel>
                                                <TextBlock Text="Default width"
                                                           Style="{StaticResource ShellMiniLabelStyle}" />
                                                <TextBlock Text="{Binding DefaultWidthDisplay}"
                                                           Style="{StaticResource ShellCatalogWidthBadgeTextStyle}" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Border Style="{StaticResource ShellCatalogEmptyStateBorderStyle}">
                    <StackPanel VerticalAlignment="Center"
                                HorizontalAlignment="Center">
                        <TextBlock Text="No items match your search"
                                   Style="{StaticResource ShellSectionTitleStyle}"
                                   TextAlignment="Center" />
                        <TextBlock Text="{Binding EmptyStateText}"
                                   Style="{StaticResource ShellCatalogEmptyStateTextStyle}"
                                   Margin="0,6,0,0"
                                   MaxWidth="220" />
                    </StackPanel>
                </Border>
            </Grid>
        </DockPanel>
    </Border>
</UserControl>
