<Window x:Class="CabinetDesigner.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:CabinetDesigner.Presentation.Views;assembly=CabinetDesigner.Presentation"
        Title="{Binding WindowTitle}"
        Width="1500"
        Height="960"
        MinWidth="1280"
        MinHeight="840"
        Background="{StaticResource ShellWindowBrush}"
        FontFamily="Segoe UI"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">
    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding NewProjectCommand}" />
        <KeyBinding Key="O" Modifiers="Ctrl" Command="{Binding OpenProjectCommand}" />
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding SaveCommand}" />
        <KeyBinding Key="W" Modifiers="Ctrl" Command="{Binding CloseProjectCommand}" />
        <KeyBinding Key="Z" Modifiers="Ctrl" Command="{Binding UndoCommand}" />
        <KeyBinding Key="Y" Modifiers="Ctrl" Command="{Binding RedoCommand}" />
        <KeyBinding Key="D0" Modifiers="Ctrl" Command="{Binding ResetZoomCommand}" />
        <KeyBinding Key="F" Modifiers="Ctrl+Shift" Command="{Binding FitToViewCommand}" />
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <views:ShellToolbarView x:Name="ToolbarRegion"
                                Grid.Row="0"
                                DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}" />

        <Grid Grid.Row="1"
              Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" MinWidth="240" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="380" MinWidth="320" />
            </Grid.ColumnDefinitions>

            <views:CatalogPanelView x:Name="CatalogRegion"
                                    Grid.Column="0"
                                    DataContext="{Binding DataContext.Catalog, RelativeSource={RelativeSource AncestorType=Window}}" />

            <GridSplitter Grid.Column="1"
                          Width="8"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext"
                          Background="{StaticResource ShellBorderSoftBrush}"
                          Cursor="SizeWE" />

            <Border Grid.Column="2"
                    Style="{StaticResource ShellCardStyle}"
                    Padding="0">
                <DockPanel>
                    <Border DockPanel.Dock="Top"
                            Style="{StaticResource ShellPanelHeaderBorderStyle}"
                            Margin="14,14,14,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding WorkspaceTitle}"
                                           Style="{StaticResource ShellSectionTitleStyle}" />
                                <TextBlock Text="{Binding WorkspaceSubtitle}"
                                           Style="{StaticResource ShellSectionSubtitleStyle}" />
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <Border Style="{StaticResource ShellBadgeStyle}"
                                        Margin="0,0,8,0">
                                    <TextBlock Text="{Binding CanvasCurrentMode}"
                                               Style="{StaticResource ShellBadgeTextStyle}" />
                                </Border>
                                <Border Style="{StaticResource ShellBadgeStyle}">
                                    <TextBlock Text="{Binding SaveStateText}"
                                               Style="{StaticResource ShellBadgeTextStyle}" />
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Background="{StaticResource ShellSurfaceDarkBrush}"
                            BorderBrush="#314152"
                            BorderThickness="1"
                            CornerRadius="12"
                            ClipToBounds="True"
                            Margin="14,0,14,14">
                        <ContentControl x:Name="CanvasRegion"
                                        Content="{Binding DataContext.Canvas.CanvasView, RelativeSource={RelativeSource AncestorType=Window}}"
                                        AutomationProperties.Name="Canvas"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch" />
                    </Border>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="3"
                          Width="8"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext"
                          Background="{StaticResource ShellBorderSoftBrush}"
                          Cursor="SizeWE" />

            <Border Grid.Column="4"
                    Style="{StaticResource ShellCardStyle}"
                    Padding="10">
                <TabControl x:Name="InspectorTabs"
                            Background="{StaticResource ShellSurfaceBrush}"
                            BorderThickness="0">
                    <TabItem Header="Properties">
                        <views:PropertyInspectorView x:Name="PropertyInspectorRegion"
                                                     DataContext="{Binding DataContext.PropertyInspector, RelativeSource={RelativeSource AncestorType=Window}}" />
                    </TabItem>
                    <TabItem Header="Run Summary">
                        <views:RunSummaryPanelView x:Name="RunSummaryRegion"
                                                   DataContext="{Binding DataContext.RunSummary, RelativeSource={RelativeSource AncestorType=Window}}" />
                    </TabItem>
                    <TabItem Header="Issues">
                        <views:IssuePanelView x:Name="IssuePanelRegion"
                                              DataContext="{Binding DataContext.IssuePanel, RelativeSource={RelativeSource AncestorType=Window}}" />
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>

        <views:StatusBarView x:Name="StatusBarRegion"
                             Grid.Row="2"
                             DataContext="{Binding DataContext.StatusBar, RelativeSource={RelativeSource AncestorType=Window}}" />
    </Grid>
</Window>
