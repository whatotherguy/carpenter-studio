<UserControl x:Class="CabinetDesigner.Presentation.Views.IssuePanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:CabinetDesigner.Presentation.Views"
             Background="Transparent">
    <Border Style="{StaticResource ShellCardStyle}"
            Padding="0">
        <DockPanel LastChildFill="True">
            <views:ShellPanelHeaderView DockPanel.Dock="Top"
                                        Title="Validation Issues"
                                        Subtitle="Project-wide diagnostics, blockers, and placeholder guidance."
                                        Margin="0,0,0,12">
                <views:ShellPanelHeaderView.RightContent>
                    <StackPanel HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Border Style="{StaticResource ShellBadgeStyle}"
                                Margin="0,0,0,6">
                            <TextBlock Text="{Binding SourceLabel}"
                                       Style="{StaticResource ShellBadgeTextStyle}" />
                        </Border>
                        <TextBlock Text="{Binding CountSummaryDisplay}"
                                   Style="{StaticResource ShellMiniLabelStyle}"
                                   HorizontalAlignment="Right" />
                    </StackPanel>
                </views:ShellPanelHeaderView.RightContent>
            </views:ShellPanelHeaderView>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0"
                            Orientation="Horizontal"
                            HorizontalAlignment="Left">
                    <Border Style="{StaticResource ShellStatusBadgeStyle}"
                            Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="Filter"
                                       Style="{StaticResource ShellMiniLabelStyle}" />
                            <TextBlock Text="{Binding FilterSummaryDisplay}"
                                       Style="{StaticResource ShellStatusBadgeTextStyle}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource ShellIssueBlockerBadgeStyle}"
                            Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="Blockers"
                                       Style="{StaticResource ShellMiniLabelStyle}" />
                            <TextBlock Text="{Binding BlockerStateDisplay}"
                                       Style="{StaticResource ShellStatusBadgeTextStyle}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource ShellStatusBadgeStyle}">
                        <StackPanel>
                            <TextBlock Text="Status"
                                       Style="{StaticResource ShellMiniLabelStyle}" />
                            <TextBlock Text="{Binding StatusMessage}"
                                       Style="{StaticResource ShellStatusBadgeTextStyle}"
                                       MaxWidth="360"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Grid Grid.Row="2">
                    <Grid Margin="2,0,2,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="140" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="Severity"
                                   Style="{StaticResource ShellMiniLabelStyle}" />
                        <TextBlock Grid.Column="1"
                                   Text="Issue"
                                   Style="{StaticResource ShellMiniLabelStyle}" />
                        <TextBlock Grid.Column="2"
                                   Text="Affected entities"
                                   Style="{StaticResource ShellMiniLabelStyle}"
                                   HorizontalAlignment="Right" />
                    </Grid>

                    <ScrollViewer Style="{StaticResource ShellCatalogListScrollViewerStyle}">
                        <ItemsControl ItemsSource="{Binding FilteredIssues}"
                                      ItemTemplate="{StaticResource IssueRowTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </ScrollViewer>

                    <Border Style="{StaticResource ShellIssueEmptyStateBorderStyle}">
                        <StackPanel VerticalAlignment="Center"
                                    HorizontalAlignment="Center">
                            <TextBlock Text="No validation issues"
                                       Style="{StaticResource ShellSectionTitleStyle}"
                                       TextAlignment="Center" />
                            <TextBlock Text="{Binding EmptyStateText}"
                                       Style="{StaticResource ShellCatalogEmptyStateTextStyle}"
                                       Margin="0,6,0,0"
                                       MaxWidth="260" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </DockPanel>
    </Border>
</UserControl>
