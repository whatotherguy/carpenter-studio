<UserControl x:Class="CabinetDesigner.Presentation.Views.ProjectStartupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:CabinetDesigner.Presentation.Views"
             Background="Transparent">
    <Border Style="{StaticResource ShellCardStyle}"
            Padding="0">
        <DockPanel LastChildFill="True">
            <views:ShellPanelHeaderView DockPanel.Dock="Top"
                                        Title="Start a Project"
                                        Subtitle="Create a new design or reopen a recent project."
                                        Margin="0,0,0,12">
                <views:ShellPanelHeaderView.RightContent>
                    <StackPanel Orientation="Vertical"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Border Style="{StaticResource ShellBadgeStyle}"
                                Margin="0,0,0,6">
                            <TextBlock Text="{Binding RecentProjects.Count, StringFormat={}{0} recent projects}"
                                       Style="{StaticResource ShellBadgeTextStyle}" />
                        </Border>
                        <TextBlock Text="{Binding EmptyStateText}"
                                   Style="{StaticResource ShellMiniLabelStyle}"
                                   HorizontalAlignment="Right"
                                   TextAlignment="Right"
                                   MaxWidth="240" />
                    </StackPanel>
                </views:ShellPanelHeaderView.RightContent>
            </views:ShellPanelHeaderView>

            <StackPanel DockPanel.Dock="Top"
                        Margin="0,0,0,16">
                <TextBlock Text="Project name"
                           Style="{StaticResource ShellMiniLabelStyle}"
                           Margin="2,0,0,6" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding NewProjectName, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource ShellToolbarTextBoxStyle}"
                             Margin="0,0,10,0" />
                    <Button Grid.Column="1"
                            Content="New Project"
                            Command="{Binding NewProjectCommand}"
                            Style="{StaticResource ShellToolbarButtonStyle}"
                            Margin="0,0,8,0" />
                    <Button Grid.Column="2"
                            Content="Refresh"
                            Command="{Binding RefreshCommand}"
                            Style="{StaticResource ShellToolbarButtonStyle}"
                            Margin="0" />
                </Grid>
            </StackPanel>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <ListBox ItemsSource="{Binding RecentProjects}"
                         SelectedItem="{Binding SelectedProject, Mode=TwoWay}"
                         BorderThickness="0"
                         Background="Transparent"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource ShellCatalogItemCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Name}"
                                                   Style="{StaticResource ShellCatalogDisplayNameStyle}" />
                                        <TextBlock Text="{Binding FilePath}"
                                                   Style="{StaticResource ShellCatalogMetaStyle}"
                                                   Margin="0,4,0,0"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding CurrentRevisionLabel, StringFormat=Revision {0}}"
                                                   Style="{StaticResource ShellMiniLabelStyle}"
                                                   Margin="0,6,0,0" />
                                    </StackPanel>

                                    <Border Grid.Column="1"
                                            Style="{StaticResource ShellCatalogWidthBadgeStyle}"
                                            VerticalAlignment="Center">
                                        <StackPanel>
                                            <TextBlock Text="Status"
                                                       Style="{StaticResource ShellMiniLabelStyle}" />
                                            <TextBlock Text="{Binding HasUnsavedChanges, StringFormat=Unsaved: {0}}"
                                                       Style="{StaticResource ShellCatalogWidthBadgeTextStyle}" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Border Background="{StaticResource ShellSurfaceSoftBrush}"
                        BorderBrush="{StaticResource ShellBorderSoftBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="18">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasProjects}" Value="False">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel VerticalAlignment="Center"
                                HorizontalAlignment="Center">
                        <TextBlock Text="No recent projects"
                                   Style="{StaticResource ShellSectionTitleStyle}"
                                   TextAlignment="Center" />
                        <TextBlock Text="{Binding EmptyStateText}"
                                   Style="{StaticResource ShellCatalogEmptyStateTextStyle}"
                                   Margin="0,6,0,0"
                                   MaxWidth="240" />
                        </StackPanel>
                </Border>
            </Grid>

            <StackPanel DockPanel.Dock="Bottom"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,16,0,0">
                <Button Content="Open Selected"
                        Command="{Binding OpenSelectedProjectCommand}"
                        Style="{StaticResource ShellToolbarButtonStyle}"
                        Margin="0" />
            </StackPanel>
        </DockPanel>
    </Border>
</UserControl>
