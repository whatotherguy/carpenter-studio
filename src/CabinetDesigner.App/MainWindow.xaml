<Window x:Class="CabinetDesigner.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle}"
        Width="1200"
        Height="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="12"
                Background="#F2F4F7"
                BorderBrush="#D0D7DE"
                BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="False">
                <StackPanel Orientation="Horizontal"
                            DockPanel.Dock="Left">
                    <TextBlock VerticalAlignment="Center"
                               Margin="0,0,8,0"
                               Text="Project" />
                    <TextBox Width="180"
                             Margin="0,0,8,0"
                             Text="{Binding PendingProjectName, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Margin="0,0,8,0"
                            Command="{Binding NewProjectCommand}"
                            Content="New" />
                    <TextBox Width="280"
                             Margin="0,0,8,0"
                             Text="{Binding PendingProjectFilePath, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Margin="0,0,8,0"
                            Command="{Binding OpenProjectCommand}"
                            Content="Open" />
                    <Button Margin="0,0,8,0"
                            Command="{Binding SaveCommand}"
                            Content="Save" />
                    <Button Margin="0,0,8,0"
                            Command="{Binding CloseProjectCommand}"
                            Content="Close" />
                    <Button Margin="0,0,8,0"
                            Command="{Binding UndoCommand}"
                            Content="Undo" />
                    <Button Command="{Binding RedoCommand}"
                            Content="Redo" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="1"
                Margin="12"
                BorderBrush="#D0D7DE"
                BorderThickness="1"
                Background="White">
            <ContentControl Content="{Binding Canvas.CanvasView}" />
        </Border>

        <Border Grid.Row="2"
                Padding="10,6"
                Background="#F8FAFC"
                BorderBrush="#D0D7DE"
                BorderThickness="0,1,0,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left"
                           FontWeight="SemiBold"
                           Text="{Binding Canvas.StatusMessage}" />
                <TextBlock DockPanel.Dock="Right"
                           Foreground="#475467"
                           Text="{Binding Canvas.CurrentMode}" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
