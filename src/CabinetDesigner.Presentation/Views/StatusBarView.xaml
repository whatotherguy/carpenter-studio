<UserControl x:Class="CabinetDesigner.Presentation.Views.StatusBarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Border Background="{StaticResource ShellSurfaceBrush}"
            BorderBrush="{StaticResource ShellBorderSoftBrush}"
            BorderThickness="0,1,0,0"
            Padding="12,8">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0"
                        Orientation="Vertical"
                        VerticalAlignment="Center">
                <Border Style="{StaticResource ShellStatusIssueBadgeStyle}"
                        HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Issues"
                                   Style="{StaticResource ShellMiniLabelStyle}"
                                   Margin="0,0,8,0" />
                        <TextBlock Text="{Binding IssueSummaryDisplay}"
                                   Style="{StaticResource ShellStatusBadgeTextStyle}" />
                    </StackPanel>
                </Border>
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{StaticResource ShellTextBrush}"
                           FontWeight="SemiBold"
                           Margin="2,6,0,0"
                           TextTrimming="CharacterEllipsis" />
            </StackPanel>

            <Border Grid.Column="1"
                    Style="{StaticResource ShellStatusBadgeStyle}"
                    HorizontalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Revision"
                               Style="{StaticResource ShellMiniLabelStyle}" />
                    <TextBlock Text="{Binding RevisionSummaryDisplay}"
                               Style="{StaticResource ShellStatusBadgeTextStyle}"
                               MaxWidth="220"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Border>

            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                <Border Style="{StaticResource ShellStatusBadgeStyle}"
                        Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="Save"
                                   Style="{StaticResource ShellMiniLabelStyle}" />
                        <TextBlock Text="{Binding SaveSummaryDisplay}"
                                   Style="{StaticResource ShellStatusBadgeTextStyle}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
